{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api"
        }
    ],
    "functions": {
        "api/index.ts": {
            "runtime": "vercel-node@latest",
            "includeFiles": [
                "src/**",
                "prisma/**"
            ]
        }
    }
}