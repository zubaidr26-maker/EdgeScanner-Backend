
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Multiple Watchlists ────────────────────────────────────
model WatchlistGroup {
  id        Int             @id @default(autoincrement())
  name      String          @default("My Watchlist")
  color     String          @default("#6366f1")
  icon      String          @default("star")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @default(now()) @updatedAt @map("updated_at")
  items     WatchlistItem[]

  @@map("watchlist_groups")
}

model WatchlistItem {
  id        Int            @id @default(autoincrement())
  ticker    String
  name      String?
  groupId   Int            @map("group_id")
  group     WatchlistGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now()) @map("created_at")

  @@unique([ticker, groupId])
  @@map("watchlist_items")
}

// Keep the old table to avoid migration issues (we'll migrate data)
model Watchlist {
  id        Int      @id @default(autoincrement())
  ticker    String   @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("watchlist")
}

model CachedStock {
  id        Int      @id @default(autoincrement())
  ticker    String   @unique
  data      Json
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("cached_stocks")
}

model StockProfile {
  ticker            String   @id
  name              String?
  sector            String?
  industry          String?
  country           String?
  marketCap         Float?   @map("market_cap")
  employees         Int?
  sharesOutstanding Float?   @map("shares_outstanding")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("stock_profiles")
}
